# ============================================================
# FILE INI UNTUK DIIMPORT KE NETLIFY
# Netlify → Site Settings → Environment Variables → Import from .env
#
# CARA PAKAI:
# 1. Isi semua nilai yang masih KOSONG di bawah ini
# 2. Buka Netlify → Site → Site Configuration → Environment Variables
# 3. Klik "Add a variable" → pilih "Import from .env file"
# 4. Paste isi file ini → Save
# ============================================================

# --- ADMIN LOGIN ---
ADMIN_USERNAME=zia
ADMIN_PASSWORD=zia123

# --- JWT SECRET (ganti dengan string acak yang panjang!) ---
# Generate di terminal: openssl rand -hex 64
SESSION_SECRET=GANTI_DENGAN_STRING_ACAK_PANJANG_MINIMAL_64_KARAKTER

# --- SUPABASE DATABASE ---
# Dari: Supabase → Settings → Database → Connection string → Transaction Pooler
# PENTING: Pakai port 6543 (bukan 5432)
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# --- SUPABASE API ---
# Dari: Supabase → Settings → API → Project URL
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co

# --- SUPABASE SERVICE ROLE KEY (RAHASIA - jangan share!) ---
# Dari: Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXXX
